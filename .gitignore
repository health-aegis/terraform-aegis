# Terraform state files — never commit state to source control
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform plan output (may contain sensitive values)
*.tfplan
tfplan

# Terraform init directories
.terraform/
.terraform.lock.hcl

# Secret variable files — keep out of source control
secrets.auto.tfvars
*.secret.tfvars
secret*.tfvars
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Crash log files
crash.log
crash.*.log

# Sensitive output files
kubeconfig
*.kubeconfig
kube_config.yaml

# Editor directories and files
.idea/
*.swp
*.swo
.DS_Store
